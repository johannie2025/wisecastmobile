<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ══ HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:id="@+id/dot_status"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/dot_grey"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="WiseCast Mobile"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tv_status"
                    android:text="Service arrêté"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <TextView
                android:text="Wise Design"
                android:textColor="#3B82F6"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ══ CARTE RÉSEAU ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:text="RÉSEAU"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_ip"
                android:text="—"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tv_clients"
                android:text="En attente d'écrans…"
                android:textColor="#22C55E"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ══ CONTRÔLE SERVICE ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_start"
                android:text="▶  Démarrer"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#22C55E"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn_stop"
                android:text="■  Arrêter"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:backgroundTint="#EF4444"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"/>
        </LinearLayout>

        <!-- ══ SÉLECTION MÉDIA ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:text="ENVOYER UN MÉDIA"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_pick_image"
                    android:text="🖼 Image"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#1E3A5F"
                    android:textColor="#60A5FA"
                    android:textSize="12sp"
                    android:enabled="false"/>

                <Button
                    android:id="@+id/btn_pick_video"
                    android:text="🎬 Vidéo"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#1E3A5F"
                    android:textColor="#60A5FA"
                    android:textSize="12sp"
                    android:enabled="false"/>

                <Button
                    android:id="@+id/btn_pick_audio"
                    android:text="🎵 Audio"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:backgroundTint="#1E3A5F"
                    android:textColor="#60A5FA"
                    android:textSize="12sp"
                    android:enabled="false"/>
            </LinearLayout>

            <!-- Fichier sélectionné -->
            <LinearLayout
                android:id="@+id/card_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/media_badge_bg"
                android:padding="10dp"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_media_name"
                    android:text=""
                    android:textColor="#93C5FD"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ COMMANDES RAPIDES ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:text="COMMANDES"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_black"
                    android:text="⬛ Écran noir"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#1F2937"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"/>

                <Button
                    android:id="@+id/btn_clear"
                    android:text="✕ Effacer"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:backgroundTint="#1F2937"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ FOOTER ══ -->
        <TextView
            android:text="Prophète Josias · Wise Design · +240555445514"
            android:textColor="#334155"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>
